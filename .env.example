# Токен вашего бота, который выдал BotFather (команда /newbot)
BOT_TOKEN=123456789:AAExampleTokenReplaceMe

# Telegram ID админов через запятую (узнать свой ID можно у бота @userinfobot)
ADMIN_IDS=111111111,222222222

# Порт, на котором будет работать сервер
PORT=3000

# Разрешаем ли работу без проверки подписи Telegram (ТОЛЬКО для локальной разработки в браузере!)
DEV_MODE=false

# Username вашего бота (без @) — нужен для формирования реферальных ссылокت.me/username?startapp=...
BOT_USERNAME=

# Папка для хранения data.json. На Railway укажите путь монтирования Volume (например /data),
# чтобы данные не терялись при передеплое. Локально можно не задавать.
DATA_DIR=
